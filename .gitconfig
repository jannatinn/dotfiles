[user]
	name = Jannatin Naim
	email = man@jannatinnaim.com
	signingkey = ~/.ssh/id_ed25519.pub
[core]
	editor = vi
[init]
	defaultBranch = main
[gpg]
	format = ssh
[commit]
	gpgsign = true
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/id_ed25519.pub
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
