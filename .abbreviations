abbr e='exit'
abbr c='clear'
abbr l='eza --icons --across'
abbr n='nvim'
abbr t='tmux'
abbr ff='fastfetch'
abbr lg='lazygit'

abbr nia='nvim $HOME/.abbreviations'

abbr ll='eza --icons --across --all --long'
abbr llg='eza --icons --across --all --long --group-directories-first'

abbr nib='nvim $HOME/.brewfile'
abbr bb='brew bundle install --file=$HOME/.brewfile'
abbr bu='brew update && brew upgrade'

abbr nin='nvim $HOME/.config/nvim/init.lua'

abbr niv='nvim $HOME/.vimrc'

abbr nit='nvim $HOME/.tmux.conf'
abbr ta='tmux attach'

abbr nigh='nvim $HOME/.config/ghostty/config.ghostty'

abbr niz='nvim $HOME/.zshrc'
abbr nizp='nvim $HOME/.zsh_plugins.txt'
abbr soz='source $HOME/.zshrc'

abbr nic='nvim main.c'
abbr crm='clang -std=c23 -Wall -Wextra -Wpedantic -Wshadow -Wconversion -fsanitize=address -fsanitize=undefined -O0 -g main.c -o main && ./main; rm -r main main.dSYM'
abbr cfm='clang-format -i -style=file main.c'

abbr nig='nvim $HOME/.gitconfig'

abbr gr='read -q "choice?You sure you want to hard reset and clean? (y/N): " && echo && git reset --hard HEAD && git clean -fd || echo "\nAborted."'
abbr gl='git log --graph --pretty=format:'\''%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'\'' --abbrev-commit'
abbr gs='git status'
abbr gd='git diff'
abbr ga='git add'
abbr gc='git commit'
abbr gp='git push -u origin HEAD'
abbr gac='git add . && git commit'
abbr gacp='git add . && git commit && git push -u origin HEAD'

abbr grb='gh browse'
abbr grc='gh repo create --private --source=. --remote=origin'

abbr nirg='nvim $HOME/.rignore'
