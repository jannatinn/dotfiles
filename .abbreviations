abbr via='vi $HOME/.abbreviations'

abbr cl='clear'
abbr ff='fastfetch'
abbr lg='lazygit'

abbr vib='vi $HOME/.brewfile'
abbr bb='brew bundle install --file=$HOME/.brewfile'
abbr bu='brew update && brew upgrade'

abbr vin='vi $HOME/.config/nvim/init.lua'

abbr vit='vi $HOME/.tmux.conf'

abbr vigh='vi $HOME/.config/ghostty/config.ghostty'

abbr viz='vi $HOME/.zshrc'
abbr vizp='vi $HOME/.zsh_plugins.txt'
abbr soz='source $HOME/.zshrc'

abbr vic='vi main.c'
abbr crm='clang -std=c23 -Wall -Wextra -Wpedantic -Wshadow -Wconversion -O0 -g -c main.c && clang main.o -o main && rm main.o && ./main; rm main'
abbr cfm='clang-format -i -style="{BasedOnStyle: LLVM, BreakBeforeBraces: Allman, IndentWidth: 4, KeepEmptyLinesAtTheStartOfBlocks: false}" main.c'
abbr cfm='clang-format -i -style=file main.c'
abbr cfrm='clang-format -i -style=file main.c && clang -std=c23 -Wall -Wextra -Wpedantic -Wshadow -Wconversion -O0 -g -c main.c && clang main.o -o main && rm main.o && ./main; rm main'

abbr vig='vi $HOME/.gitconfig'

abbr gr='read -q "choice?You sure you want to hard reset and clean? (y/N): " && echo && git reset --hard HEAD && git clean -fd || echo "\nAborted."'
abbr gl='git log --graph --pretty=format:'\''%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'\'' --abbrev-commit'
abbr gs='git status'
abbr gd='git diff'
abbr ga='git add'
abbr gc='git commit'
abbr gp='git push -u origin HEAD'
abbr gac='git add . && git commit'
abbr gacp='git add . && git commit && git push -u origin HEAD'

abbr ghb='gh browse'
abbr ghrc='gh repo create my-project --private --source=. --remote=upstream'
